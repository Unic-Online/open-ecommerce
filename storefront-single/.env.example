# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the storefront template.
#
# Single source of truth: src/env.ts (serverEnv + clientEnv). Every var below is
# read there. Copy this file to .env.local and fill in the values you need
# (NEVER commit .env.local). Required vars are validated at production cold start
# by instrumentation.ts → assertProdEnvOrThrow(); missing them fails the deploy
# in Vercel logs instead of 500ing the first customer.
#
# Curated by hand (grouped required-vs-optional). If you add a new var, add it to
# src/env.ts as a literal `process.env.X` read and document it here.
# ─────────────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════════════
# REQUIRED FOR CHECKOUT — the store cannot take a real order without these.
# (Validated at boot in production; dev/preview/test run without them.)
# ═════════════════════════════════════════════════════════════════════════════

# MongoDB connection string. Atlas → Connect → Drivers → copy the SRV URI.
MONGODB_URI=
# Mongo database name. Optional override (default comes from src/site.config).
# Playwright e2e overrides this to an isolated DB.
MONGODB_DB_NAME=

# Resend API key for transactional email + audience sync. resend.com → API Keys.
RESEND_API_KEY=

# Revolut Merchant secret key (`sk_...`), server-only.
# Revolut Business → Merchant API → API keys.
REVOLUT_SECRET_KEY=
# HMAC secret that verifies Revolut webhook signatures. The webhook handler
# rejects everything until this is set. Obtain it from `pnpm revolut:webhook create`.
REVOLUT_WEBHOOK_SIGNING_SECRET=
# Revolut public key (`pk_...`) for the browser SDK. Without it the payment
# widgets render "not configured". Revolut Business → Merchant API → API keys.
NEXT_PUBLIC_REVOLUT_PUBLIC_KEY=

# Admin dashboard password (single operator). Choose any strong value.
ADMIN_PASSWORD=
# HMAC secret for admin sessions + account magic-links + cart-recovery URLs
# (shared — rotating it logs everyone out and invalidates all recovery links).
# Generate with: openssl rand -hex 32
CART_RECOVERY_HMAC_SECRET=
# Bearer secret the Vercel cron sends to authorize the recovery / CAPI-replay
# cron routes. Generate with: openssl rand -hex 32
CART_RECOVERY_CRON_SECRET=

# Meta (Facebook) Pixel ID — used by both the browser Pixel and server CAPI.
# Required in production because a missing ID silently drops every Purchase
# conversion (browser + cron replay). Events Manager → Data Sources → your Pixel.
NEXT_PUBLIC_META_PIXEL_ID=
# Meta Conversions API access token (server-side).
# Events Manager → Settings → Conversions API → Generate access token.
META_CAPI_ACCESS_TOKEN=


# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL INTEGRATIONS — absent means the feature silently disables.
# ═════════════════════════════════════════════════════════════════════════════

# ── Payments mode ──
# Revolut API mode: `sandbox` routes to the sandbox host; anything else = live.
REVOLUT_API_MODE=
# Revolut SDK mode for the browser widgets (`sandbox`/`live`). Keep in sync with
# REVOLUT_API_MODE.
NEXT_PUBLIC_REVOLUT_API_MODE=

# ── Analytics (Google Tag Manager / GA4) ──
# GTM container ID. Absent = GTM not injected.
NEXT_PUBLIC_GTM_ID=
# GA4 measurement ID (e.g. G-XXXXXXXXXX). Loads gtag.js directly for ecommerce
# funnel events (view_item, add_to_cart, begin_checkout, purchase). Absent = GA4
# not loaded.
NEXT_PUBLIC_GA_ID=
# Google Ads conversion-tracking ID (e.g. AW-XXXXXXXXXX). Configured through the
# same gtag.js install: page pings build remarketing audiences and capture
# ?gclid= into first-party _gcl_* cookies (conversion-linker behavior), gated by
# Consent Mode v2 ad_storage. Absent = no Ads tag.
NEXT_PUBLIC_GOOGLE_ADS_ID=

# ── Meta CAPI tuning ──
# Meta Test Events tag — forwarded as `test_event_code` while debugging in
# Events Manager → Test Events.
META_CAPI_TEST_EVENT_CODE=
# `1` disables server-side Purchase CAPI (the cron + webhook senders no-op).
META_CAPI_DISABLE_SERVER_PURCHASE=

# ── Observability (Grafana Faro / browser RUM) ──
# Faro collector URL. Absent = browser observability stays off.
NEXT_PUBLIC_FARO_URL=
# Optional Faro app-name override (default `storefront`).
NEXT_PUBLIC_FARO_APP_NAME=

# ── Error sink (backend) ──
# Optional HTTP error-sink URL. Absent = errors logged to stderr only.
ERROR_SINK_URL=
# Bearer token for the error sink, sent only when ERROR_SINK_URL is set.
ERROR_SINK_TOKEN=

# ── Abandoned-cart plugin (client feature flags; `1` enables) ──
# Master toggle — off makes <AbandonedCartPlugin /> render nothing.
NEXT_PUBLIC_ABANDONED_CART_ENABLED=
# Exit-intent discount popup.
NEXT_PUBLIC_ABANDONED_CART_EXIT_INTENT=
# Experiment: intercept the first mobile back press with the exit-intent popup.
# Off by default — costs one extra back press; keep measurable & reversible.
NEXT_PUBLIC_ABANDONED_CART_BACK_INTERCEPT=
# Server-side cart persistence/sync.
NEXT_PUBLIC_ABANDONED_CART_CART_SYNC=
# Checkout-draft persistence (shipping draft in localStorage).
NEXT_PUBLIC_ABANDONED_CART_CHECKOUT_DRAFT=
# QA test-mode — collapses cooldowns/thresholds so e2e can run the full
# H1/H24/H72 sequence quickly.
NEXT_PUBLIC_ABANDONED_CART_TEST_MODE=

# ── Abandoned-cart plugin (server flags) ──
# `1`/`0` force the abandoned-cart dry-run; unset = derived from MONGODB_URI presence.
ABANDONED_CART_DRY_RUN=
# `0` disables recovery-email sends (state still advances).
ABANDONED_CART_RECOVERY_EMAIL_ENABLED=
# `1` logs recovery-email intent without calling Resend.
RECOVERY_EMAIL_DRY_RUN=

# ── Staging / test gates ──
# `1` short-circuits every outbound email (Playwright + manual debugging).
EMAIL_DRY_RUN=
# `1` opens the `/api/test-only/*` debug endpoints (Playwright webServer).
# NEVER set this on the production environment.
E2E_DEBUG_ENDPOINTS=
